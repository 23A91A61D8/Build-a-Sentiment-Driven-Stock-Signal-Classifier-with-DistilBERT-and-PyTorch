# Stock ticker symbol to analyze
TICKER=AAPL

# Date range for historical stock data download
START_DATE=2018-01-01
END_DATE=2023-12-31

# Chronological split: data on/before this date goes to training, after goes to test
TRAIN_END_DATE=2021-12-31

# Threshold for classifying UP/DOWN signals (as decimal, e.g. 0.005 = 0.5%)
UP_DOWN_THRESHOLD=0.005
